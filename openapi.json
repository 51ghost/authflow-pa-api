{
  "openapi": "3.0.3",
  "info": {
    "title": "AuthFlow PA API",
    "description": "Healthcare prior-authorization authentication flow",
    "version": "1.0.0",
    "x-category": "Healthcare",
    "x-long-description": "The AuthFlow PA API provides production-ready healthcare prior-authorization authentication flow. Fully compatible with RapidAPI marketplace, ready for monetization.",
    "x-badges": [
      {
        "name": "production-ready",
        "color": "green"
      },
      {
        "name": "health",
        "color": "blue"
      }
    ]
  },
  "servers": [
    {
      "url": "https://authflow-pa-api-production.up.railway.app",
      "description": "Production"
    }
  ],
  "paths": {
    "/v1/auth/login": {
      "post": {
        "summary": "Authenticate user",
        "operationId": "v1_auth_login",
        "parameters": [
          {
            "name": "x-api-key",
            "in": "header",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "API key for authentication"
          }
        ],
        "responses": {
          "200": {
            "description": "Success",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized"
          },
          "429": {
            "description": "Rate limit exceeded"
          }
        }
      }
    },
    "/v1/auth/register": {
      "post": {
        "summary": "Register new user",
        "operationId": "v1_auth_register",
        "parameters": [
          {
            "name": "x-api-key",
            "in": "header",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "API key for authentication"
          }
        ],
        "responses": {
          "200": {
            "description": "Success",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized"
          },
          "429": {
            "description": "Rate limit exceeded"
          }
        }
      }
    },
    "/v1/auth/verify": {
      "post": {
        "summary": "Verify MFA token",
        "operationId": "v1_auth_verify",
        "parameters": [
          {
            "name": "x-api-key",
            "in": "header",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "API key for authentication"
          }
        ],
        "responses": {
          "200": {
            "description": "Success",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized"
          },
          "429": {
            "description": "Rate limit exceeded"
          }
        }
      }
    },
    "/v1/authorization/request": {
      "post": {
        "summary": "Submit prior authorization request",
        "operationId": "v1_authorization_request",
        "parameters": [
          {
            "name": "x-api-key",
            "in": "header",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "API key for authentication"
          }
        ],
        "responses": {
          "200": {
            "description": "Success",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized"
          },
          "429": {
            "description": "Rate limit exceeded"
          }
        }
      }
    },
    "/v1/authorization/{id}": {
      "get": {
        "summary": "Get authorization status",
        "operationId": "v1_authorization_id",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "x-api-key",
            "in": "header",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "API key for authentication"
          }
        ],
        "responses": {
          "200": {
            "description": "Success",
