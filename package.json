{
  "name": "authflow-pa-api",
  "version": "1.0.0",
  "description": "AuthFlow PA API — Secure authentication flow API with passwordless, OAuth2, JWT, and multi-factor support",
  "main": "src/index.js",
  "scripts": {
    "start": "node src/index.js",
    "dev": "nodemon src/index.js",
    "test": "jest --coverage --forceExit",
    "test:watch": "jest --watch --forceExit",
    "lint": "eslint src/ tests/",
    "db:migrate": "node src/db/migrate.js",
    "db:seed": "node src/db/seed.js"
  },
  "keywords": [
    "authflow",
    "authentication",
    "api",
    "passwordless",
    "jwt",
    "oauth2",
    "mfa",
    "prior-authorization"
  ],
  "license": "MIT",
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "express-rate-limit": "^7.5.0",
    "helmet": "^8.0.0",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "nodemailer": "^6.9.16",
    "speakeasy": "^2.0.0",
    "uuid": "^11.0.5",
    "zod": "^3.24.1",
    "better-sqlite3": "^11.7.0",
    "winston": "^3.17.0"
  },
  "devDependencies": {
    "eslint": "^9.17.0",
    "jest": "^29.7.0",
    "nodemon": "^3.1.9",
    "supertest": "^7.0.0"
  }
}
